# ============================================================
# DATABASE — Get from neon.tech (free)
# ============================================================
DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"

# ============================================================
# REDIS — Get from upstash.com (free)
# ============================================================
UPSTASH_REDIS_REST_URL="https://YOUR-URL.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR-TOKEN"

# ============================================================
# NEXTAUTH — Generate secret with: openssl rand -base64 32
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="GENERATE-THIS-DONT-MAKE-IT-UP"

# ============================================================
# GOOGLE OAUTH — Get from console.cloud.google.com
# ============================================================
GOOGLE_CLIENT_ID="XXXX.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-XXXX"

# ============================================================
# CLOUDINARY — Get from cloudinary.com dashboard
# ============================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="000000000000"
CLOUDINARY_API_SECRET="XXXXXXXXXXXX"
CLOUDINARY_UPLOAD_PRESET="uttarkesri_articles"

# ============================================================
# FIREBASE FCM — Get from console.firebase.google.com
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy-XXXX"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="uttar-kesri.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="uttar-kesri"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="uttar-kesri.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="000000000"
NEXT_PUBLIC_FIREBASE_APP_ID="1:000:web:XXXX"
NEXT_PUBLIC_FIREBASE_VAPID_KEY="BExxx-XXXX"
FIREBASE_ADMIN_PROJECT_ID="uttar-kesri"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk@uttar-kesri.iam.gserviceaccount.com"
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----"

# ============================================================
# MSG91 SMS OTP — Get from msg91.com (Indian SMS provider)
# ============================================================
MSG91_API_KEY="XXXXXXXXXXXX"
MSG91_TEMPLATE_ID="XXXXXXXXXXXX"
MSG91_SENDER_ID="UTKESRI"

# ============================================================
# OPENWEATHERMAP — Get from openweathermap.org (free tier)
# ============================================================
OPENWEATHER_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ============================================================
# VERCEL CRON PROTECTION — Generate with: openssl rand -base64 32
# ============================================================
CRON_SECRET="GENERATE-THIS"

# ============================================================
# SITE CONFIG
# ============================================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="उत्तर केसरी"
NEXT_PUBLIC_SITE_TAGLINE="उत्तर प्रदेश की आवाज़"

# ============================================================
# ADMIN (for first login after seed)
# ============================================================
ADMIN_EMAIL="admin@uttarkesri.com"
ADMIN_PASSWORD="Admin@123"
